{
  "name": "orangehrm-cucumber-playwright",
  "version": "1.0.0",
  "description": "Cucumber BDD Playwright TypeScript framework for OrangeHRM",
  "scripts": {
    "test": "node scripts/run-tests.js",
    "test:smoke": "node scripts/run-tests.js @smoke",
    "test:regression": "node scripts/run-tests.js @regression",
    "test:login": "node scripts/run-tests.js @login",
    "test:employee": "node scripts/run-tests.js @employee",
    "report": "node scripts/generate-report.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "dependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.44.0",
    "dotenv": "^16.4.5",
    "multiple-cucumber-html-reporter": "^3.6.2",
    "mysql2": "^3.9.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "allure-commandline": "^2.43.0",
    "allure-cucumberjs": "^3.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}